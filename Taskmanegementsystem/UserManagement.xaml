<Page x:Class="Taskmanegementsystem.UserManagement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Taskmanegementsystem"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserManagement">

    <Grid Background="White">
        <Label Content="Task ID :" FontSize="20" HorizontalAlignment="Left" Margin="44,54,0,0" VerticalAlignment="Top"/>
        <Label Content="Title :" FontSize="20" HorizontalAlignment="Left" Margin="44,113,0,0" VerticalAlignment="Top"/>
        <Label Content="Discription :" FontSize="15" HorizontalAlignment="Left" Margin="44,172,0,0" VerticalAlignment="Top"/>
        <Label Content="Statues :" FontSize="20" HorizontalAlignment="Left" Margin="400,61,0,0" VerticalAlignment="Top"/>
        <Label Content="Employee Name :" FontSize="20" HorizontalAlignment="Left" Margin="395,105,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="idtextbox" HorizontalAlignment="Left" Margin="138,65,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="titletextbox" HorizontalAlignment="Left" Margin="138,122,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="discriptiontextbox" HorizontalAlignment="Left" Margin="138,178,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="nametextbox" HorizontalAlignment="Left" Margin="564,113,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <ComboBox x:Name="statuescombo" HorizontalAlignment="Left" Margin="564,61,0,0" VerticalAlignment="Top" Width="120">
            <ComboBoxItem>Completed</ComboBoxItem>
            <ComboBoxItem>In Progress</ComboBoxItem>
            <ComboBoxItem>Pending</ComboBoxItem>
        </ComboBox>
        <Button Content="Add" HorizontalAlignment="Left" Margin="584,266,0,0" VerticalAlignment="Top" Height="36" Width="100" Click="Add_Button_Click"/>
        <Button Content="Edit" HorizontalAlignment="Left" Margin="300,266,0,0" VerticalAlignment="Top" Height="36" Width="100" Click="Edit_Button_Click"/>
        <Button Content="Delete" HorizontalAlignment="Left" Margin="138,266,0,0" VerticalAlignment="Top" Height="36" Width="100" Click="Delete_Button_Click"/>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" Text="User Manegement System" VerticalAlignment="Top" FontSize="20" Height="26" Width="800"/>
        <DataGrid x:Name="datagridss" Margin="142,326,122,22"></DataGrid>
        <Button Content="Search" HorizontalAlignment="Left" Margin="442,266,0,0" VerticalAlignment="Top" Height="36" Width="102" Click="Button_Click"/>
    </Grid>
</Page>
